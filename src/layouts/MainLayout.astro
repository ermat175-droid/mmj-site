---
import '../styles/global.css';
const { title } = Astro.props;
---
<html lang="ru" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-white text-mmj-indigo antialiased">
    <nav class="bg-mmj-indigo text-white py-5 px-6 md:px-20 flex justify-between items-center sticky top-0 z-50 border-b border-mmj-gold/20">
      <div class="text-3xl font-bold tracking-tighter text-mmj-gold">MMJ</div>
      
      <div class="hidden md:flex gap-10 uppercase text-[10px] tracking-[0.2em] font-bold">
        <a href="/" class="hover:text-mmj-gold transition">Главная</a>
        <a href="#catalog" class="hover:text-mmj-gold transition">Каталог</a>
        <a href="#about" class="hover:text-mmj-gold transition">О компании</a>
        <a href="#contacts" class="hover:text-mmj-gold transition">Контакты</a>
      </div>

      <div class="flex items-center gap-4">
        <a href="tel:+77000000000" class="hidden lg:block text-sm font-semibold hover:text-mmj-gold transition">+7 (708) 249-46-09</a>
        <a href="https://wa.me/77082494609" class="bg-mmj-gold text-mmj-indigo px-6 py-2.5 font-bold text-xs uppercase tracking-wider hover:bg-white transition-colors">WhatsApp</a>
      </div>
    </nav>
    
    <slot />

    <footer class="bg-mmj-indigo text-white py-20 px-6 md:px-20 border-t border-mmj-gold/10">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12">
        <div class="col-span-1 md:col-span-2">
          <div class="text-3xl font-bold text-mmj-gold mb-6">MMJ</div>
          <p class="text-gray-400 text-sm max-w-sm leading-relaxed">Прямые поставки строительных материалов для застройщиков и подрядчиков. Работа с тендерами и крупными объектами.</p>
        </div>
        <div>
          <h4 class="font-bold mb-6 uppercase text-[10px] tracking-widest text-mmj-gold">Контакты</h4>
          <div class="text-sm text-gray-400 space-y-3">
            <p>г.Тараз</p>
            <p>info@mmj.kz</p>
            <p>Пн-Пт: 09:00 — 18:00</p>
          </div>
        </div>
        <div>
          <h4 class="font-bold mb-6 uppercase text-[10px] tracking-widest text-mmj-gold">Разделы</h4>
          <div class="flex flex-col gap-3 text-sm text-gray-400">
            <a href="#catalog" class="hover:text-mmj-gold">Каталог продукции</a>
            <a href="#about" class="hover:text-mmj-gold">Условия поставок</a>
            <a href="#contacts" class="hover:text-mmj-gold">Получить КП</a>
          </div>
        </div>
      </div>
    </footer>
    <script>
    if (window.netlifyIdentity) {
        window.netlifyIdentity.on("init", user => {
            if (!user) {
                window.netlifyIdentity.on("login", () => {
                    document.location.href = "/admin/";
                    });
                    }
                    });
                    }</script>
  </body>
</html>